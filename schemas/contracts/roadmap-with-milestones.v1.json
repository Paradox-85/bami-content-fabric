{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/contracts/roadmap-with-milestones.v1.json",
  "title": "Roadmap With Milestones",
  "description": "Content contract for roadmap-with-milestones family — expressive horizontal roadmap with phase regions, milestone markers, connectors, and editable labels",
  "type": "object",
  "properties": {
    "phases": {
      "description": "Ordered list of roadmap phases/sections",
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "description": "Phase heading",
            "type": "string",
            "minLength": 1
          },
          "subtitle": {
            "description": "Phase sub-heading or short description",
            "type": "string"
          },
          "milestones": {
            "description": "Milestones within this phase",
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "description": "Milestone label text",
                  "type": "string",
                  "minLength": 1
                },
                "date": {
                  "description": "Milestone date or period",
                  "type": "string"
                },
                "icon": {
                  "description": "Optional icon key for milestone marker",
                  "type": "string"
                }
              },
              "required": ["label"]
            }
          }
        },
        "required": ["title", "milestones"]
      }
    }
  },
  "required": ["phases"],
  "additionalProperties": false
}
