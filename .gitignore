# Agent session artifacts (keep skills/, mermaid-cache/, ignore temp + historical sessions)
.pi/temp/
.pi/mermaid-cache/
.pi/context/
.pi/plan/
.pi/plan.md
.pi/implementation/
.pi/research/
.pi/review/
.pi/temp_session_slug.txt
.pi/templates/
# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# Generated decks (per-engagement outputs are not committed by default)
*.pptx
!templates/template.pptx
!templates/kvi/template.pptx
# Node dependencies (installed via npm, regenerable)
node_modules/
package-lock.json

# External downloaded Envato asset packs (multi-GB, regenerable) — not committed
templates/media/from_envato/

# Intermediate asset-processing working dirs
templates/media/_staging/
templates/media/_raw_archive/
templates/media/_envato_ingest/
templates/media/_svg_input_ingest/
# Archives and binary files (not committed to version control)
*.zip
*.tar.gz
*.tgz
*.7z
*.rar
*.exe
*.msi
*.dll
*.so
*.dylib
*.pdf
# Per-engagement client decks stay local; only the generic _sample is committed
clients/*
!clients/_sample/
!clients/README.md
# Local task/scratch notes
tasks.txt
schema_dump.json
