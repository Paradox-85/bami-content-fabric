{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BAMi SVG Variant Index Schema",
  "description": "JSON Schema for templates/media/reference/library/svg-variant-index.yaml. Validates the machine-readable index of classified SVGs with variant group metadata.",
  "type": "object",
  "required": [
    "format_version",
    "groups"
  ],
  "properties": {
    "format_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version of the index schema"
    },
    "description": {
      "type": "string"
    },
    "groups": {
      "type": "object",
      "description": "Variant groups keyed by group_id (derived from set_slug_hex_hash)",
      "additionalProperties": {
        "type": "object",
        "required": [
          "canonical_category",
          "members"
        ],
        "properties": {
          "canonical_category": {
            "type": "string",
            "description": "Canonical category ID from categories.yaml"
          },
          "style_axis": {
            "type": "string",
            "enum": [
              "color",
              "format",
              "none"
            ],
            "description": "Axis of visual variation within this group"
          },
          "selectable_for_random": {
            "type": "boolean"
          },
          "all_rendered": {
            "type": "boolean"
          },
          "rendered_count": {
            "type": "integer",
            "minimum": 0
          },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "filename"
              ],
              "properties": {
                "filename": {
                  "type": "string",
                  "description": "SVG filename in templates/media/reference/input/"
                },
                "rendered": {
                  "type": "boolean"
                },
                "selectable": {
                  "type": "boolean"
                },
                "reason": {
                  "type": "string"
                },
                "canonical_category": {
                  "type": "string",
                  "description": "Per-member override of group canonical_category"
                },
                "keep": {
                  "type": "string",
                  "enum": [
                    "Y",
                    "N"
                  ],
                  "description": "Whether to keep this file in the library"
                },
                "review_status": {
                  "type": "string",
                  "description": "Human review status (e.g. quarantined)"
                },
                "review_reason": {
                  "type": "string",
                  "description": "Explanation for review status decision"
                },
                "evidence": {
                  "type": "object",
                  "description": "Evidence supporting classification/review",
                  "properties": {
                    "method": {
                      "type": "string",
                      "enum": [
                        "checked_in_filename_keyword",
                        "checked_in_registry_provenance",
                        "human_visual_review",
                        "quarantine_review_required"
                      ],
                      "description": "How this classification was determined"
                    },
                    "reviewer": {
                      "type": "string",
                      "description": "Person who performed the review"
                    },
                    "review_date": {
                      "type": "string",
                      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                      "description": "Date of review (ISO 8601 date only)"
                    },
                    "checksum": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$",
                      "description": "SHA-256 checksum of the source SVG file"
                    },
                    "provenance": {
                      "type": "string",
                      "description": "Provenance trail or source reference"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
